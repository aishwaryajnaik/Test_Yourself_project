{
  "name": "test-yourself-tests",
  "version": "1.0.0",
  "scripts": {
    "test:unit": "jest --testPathPattern=unit --runInBand",
    "test:api": "cucumber-js --name \".*API.*\" features/api-test.feature",
    "test:e2e": "cucumber-js features/test-generation.feature",
    "test:e2e:headed": "cucumber-js --parallel 1 features/test-generation.feature",
    "test": "npm run test:unit && npm run test:api && npm run test:e2e"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.0.1",
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "axios": "^1.6.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
